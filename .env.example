# Copy to .env (or point SAT_TRACKER_ENV at it). Everything here can also
# be entered in the app's ⚙️ Pipeline configuration panel instead — the
# panel persists to data/user_config.json. Env vars mainly matter for the
# AIS collector container, which runs headless.

# --- AIS recording (required for the collector) -------------------------
# Free key: https://aisstream.io
AIS_API_KEY=

# Optional: pin the collector to one area instead of watching every
# location saved in the app ("min_lon,min_lat,max_lon,max_lat")
#AOI_BBOX=-6.2,35.75,-5.3,36.2

# --- Sentinel-1 imagery (required for live runs) ------------------------
# CDSE S3 keys — NOT the OAuth client! Generate at
# https://eodata-s3keysmanager.dataspace.copernicus.eu (free account)
CDSE_S3_KEY=
CDSE_S3_SECRET=

# --- Detection (pick one backend; 'replicate' is the default) -----------
# Token: https://replicate.com/account/api-tokens (usage billed to you;
# a full satellite pass costs a few cents on CPU hardware)
REPLICATE_API_TOKEN=
#REPLICATE_MODEL=gsulpizio/xview3-vessel-detect

# Alternative backends:
#DETECTOR_BACKEND=roboflow
#ROBOFLOW_API_KEY=
#ROBOFLOW_MODEL_ID=sar-ship-dataset-ogvbz/1
